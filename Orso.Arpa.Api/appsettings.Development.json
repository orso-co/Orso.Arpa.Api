        "StackBlockedRequests": false,
        "EndpointWhitelist": [ "options:*", "post:/graphql", "post:/api/audience/search" ],
        "HttpStatusCode": 429,
        "GeneralRules": [
            {
                "Endpoint": "((post)|(put)|(delete)):*",
